{
  "name": "trust-signature-layer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Trust Signature Layer reference MVP: canonical objects, signatures, Merkle proofs, verifier, CLI, and service wrappers.",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "chain": "node scripts/run-hardhat.cjs node",
    "contracts:compile": "node scripts/run-hardhat.cjs compile",
    "contracts:test": "node scripts/run-hardhat.cjs test contracts/test/CheckpointRegistry.hardhat.cjs",
    "contracts:deploy:local": "node scripts/run-hardhat.cjs run contracts/scripts/deploy-local.cjs --network localhost",
    "deploy:base-sepolia": "node scripts/run-hardhat.cjs run contracts/scripts/deploy-base-sepolia.cjs --network baseSepolia",
    "deploy:base-sepolia:e2e": "tsx scripts/base-sepolia-e2e.ts",
    "deploy:validate": "tsx scripts/validate-deployment.ts",
    "deploy:base:dry-run": "tsx scripts/base-mainnet-dry-run.ts",
    "cli": "tsx clients/cli/src/index.ts",
    "demo": "tsx clients/cli/src/index.ts demo",
    "relay": "tsx services/relay-node/src/index.ts",
    "log": "tsx services/log-node/src/index.ts",
    "resolver": "tsx services/resolver-node/src/index.ts",
    "checkpoint-submitter": "tsx services/checkpoint-submitter/src/index.ts",
    "scoring-provider": "tsx services/scoring-provider/src/index.ts",
    "auditor": "tsx services/auditor-node/src/index.ts",
    "verifier": "tsx services/verifier-api/src/index.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "build:web-verifier": "esbuild clients/web-verifier/src/browser-entry.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=clients/web-verifier/public/verifier.bundle.js",
    "web-verifier": "npm run build:web-verifier && tsx clients/web-verifier/src/index.ts",
    "agent-sidecar": "tsx clients/agent-sidecar/src/index.ts",
    "load-test:events": "tsx scripts/load-test-events.ts",
    "load-test:full-path": "tsx scripts/load-test-full-path.ts",
    "load-test:full-path:1m": "TSL_FULL_PATH_COUNT=1000000 TSL_FULL_PATH_SAMPLES=100 TSL_FULL_PATH_CONCURRENCY=100 npm run load-test:full-path",
    "zk:compile": "mkdir -p circuits/build && npx circom2 circuits/identity_age_threshold.circom --r1cs --wasm --sym -o circuits/build && npx circom2 circuits/reciprocal_receipt_count_threshold.circom --r1cs --wasm --sym -o circuits/build",
    "zk:setup": "node scripts/zk-setup.cjs",
    "zk:test": "npm run zk:setup && tsx scripts/zk-test.ts",
    "zk:manifest": "tsx scripts/zk-manifest.ts",
    "deploy:base-sepolia:verify": "TSL_VERIFY_CONTRACTS=true npm run deploy:base-sepolia",
    "release:check": "node scripts/release-check.cjs",
    "release:rc": "node scripts/release-rc.cjs",
    "release:production-check": "TSL_RELEASE_RC_RUN_FULL_PATH_SMOKE=0 npm run release:rc && npm run deploy:validate && npm run deploy:base:dry-run",
    "conformance:rc2": "tsx scripts/conformance.ts rc2",
    "conformance:rc3": "tsx scripts/conformance.ts rc3",
    "conformance:rc4": "tsx scripts/conformance.ts rc4",
    "conformance:spec": "tsx scripts/conformance.ts spec",
    "parity:python": "cd packages/core-python && python3 -m pytest",
    "parity:rust": "node scripts/parity-rust.cjs"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.2",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "circom": "^0.5.46",
    "circom_tester": "^0.0.24",
    "circom2": "^0.2.22",
    "esbuild": "^0.28.0",
    "hardhat": "^2.28.6",
    "snarkjs": "^0.7.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
