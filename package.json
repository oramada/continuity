{
  "name": "continuity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Continuity Protocol developer preview: Trust Signature Layer canonical objects, signatures, Merkle proofs, verifier, CLI, and service wrappers.",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "chain": "node scripts/run-hardhat.cjs node",
    "contracts:compile": "node scripts/run-hardhat.cjs compile",
    "contracts:test": "node scripts/run-hardhat.cjs test",
    "contracts:deploy:local": "node scripts/run-hardhat.cjs run contracts/scripts/deploy-local.cjs --network localhost",
    "deploy:base-sepolia": "node scripts/run-hardhat.cjs run contracts/scripts/deploy-base-sepolia.cjs --network baseSepolia",
    "deploy:base-sepolia:e2e": "tsx scripts/base-sepolia-e2e.ts",
    "deploy:validate": "tsx scripts/validate-deployment.ts",
    "deploy:base:dry-run": "tsx scripts/base-mainnet-dry-run.ts",
    "cli": "tsx clients/cli/src/index.ts",
    "demo": "tsx clients/cli/src/index.ts demo",
    "relay": "tsx services/relay-node/src/index.ts",
    "log": "tsx services/log-node/src/index.ts",
    "resolver": "tsx services/resolver-node/src/index.ts",
    "checkpoint-submitter": "tsx services/checkpoint-submitter/src/index.ts",
    "scoring-provider": "tsx services/scoring-provider/src/index.ts",
    "auditor": "tsx services/auditor-node/src/index.ts",
    "verifier": "tsx services/verifier-api/src/index.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "build:web-verifier": "esbuild clients/web-verifier/src/browser-entry.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=clients/web-verifier/public/verifier.bundle.js",
    "web-verifier": "npm run build:web-verifier && tsx clients/web-verifier/src/index.ts",
    "agent-sidecar": "tsx clients/agent-sidecar/src/index.ts",
    "load-test:events": "tsx scripts/load-test-events.ts",
    "load-test:full-path": "tsx scripts/load-test-full-path.ts",
    "load-test:full-path:1m": "TSL_FULL_PATH_COUNT=1000000 TSL_FULL_PATH_SAMPLES=100 TSL_FULL_PATH_CONCURRENCY=100 npm run load-test:full-path",
    "zk:compile": "mkdir -p circuits/build && npx circom2 circuits/identity_age_threshold.circom --r1cs --wasm --sym -o circuits/build && npx circom2 circuits/reciprocal_receipt_count_threshold.circom --r1cs --wasm --sym -o circuits/build && npx circom2 circuits/revocation_set_non_membership.circom --r1cs --wasm --sym -o circuits/build && npx circom2 circuits/agent_scope_compliance.circom --r1cs --wasm --sym -o circuits/build",
    "zk:compile:production-interfaces": "mkdir -p circuits/build-production && for f in circuits/production_*.circom; do npx circom2 \"$f\" --r1cs --wasm --sym -o circuits/build-production; done",
    "zk:setup:production-candidate": "node scripts/zk-production-setup.cjs",
    "zk:test:production-candidate": "node scripts/zk-production-test.cjs",
    "zk:manifest:production-candidate": "node scripts/zk-production-manifest.cjs",
    "zk:setup": "node scripts/zk-setup.cjs",
    "zk:test": "npm run zk:setup && tsx scripts/zk-test.ts",
    "zk:manifest": "tsx scripts/zk-manifest.ts",
    "deploy:base-sepolia:verify": "TSL_VERIFY_CONTRACTS=true npm run deploy:base-sepolia",
    "release:check": "node scripts/release-check.cjs",
    "release:rc": "node scripts/release-rc.cjs",
    "release:production-check": "TSL_RELEASE_RC_RUN_FULL_PATH_SMOKE=0 npm run release:rc && npm run deploy:validate && npm run deploy:base:dry-run",
    "release:mainnet-check": "node scripts/release-mainnet-check.cjs",
    "evidence:mainnet-report": "node scripts/mainnet-evidence-report.cjs",
    "integration:postgres": "tsx scripts/mainnet-postgres-smoke.ts",
    "integration:cli-sidecar-v2": "tsx scripts/mainnet-cli-sidecar-v2-smoke.ts",
    "integration:hosted-service": "tsx scripts/mainnet-hosted-service-smoke.ts",
    "conformance:rc0": "tsx scripts/conformance.ts rc0",
    "conformance:rc1": "tsx scripts/conformance.ts rc1",
    "conformance:rc2": "tsx scripts/conformance.ts rc2",
    "conformance:rc3": "tsx scripts/conformance.ts rc3",
    "conformance:rc4": "tsx scripts/conformance.ts rc4",
    "conformance:spec": "tsx scripts/conformance.ts spec",
    "conformance:zk-production": "tsx scripts/conformance.ts zk-production",
    "conformance:settlement-offline": "tsx scripts/conformance.ts settlement-offline",
    "conformance:graph-research": "tsx scripts/conformance.ts graph-research",
    "conformance:mainnet": "tsx scripts/conformance.ts mainnet",
    "parity:python": "python3 scripts/parity-python.py",
    "parity:rust": "node scripts/parity-rust.cjs"
  },
  "dependencies": {
    "@ethereumjs/trie": "^6.2.1",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^1.8.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "buffer": "^6.0.3",
    "commander": "^14.0.2",
    "ethers": "^6.16.0",
    "events": "^3.3.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "circom": "^0.5.46",
    "circom_tester": "^0.0.24",
    "circom2": "^0.2.22",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "esbuild": "^0.28.0",
    "hardhat": "^2.28.6",
    "snarkjs": "^0.7.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "overrides": {
    "js-yaml": "4.1.1",
    "jsonpath@1.3.0": {
      "underscore": "1.13.8"
    },
    "mocha@8.4.0": {
      "diff": "5.2.2",
      "js-yaml": "4.1.1",
      "minimatch": "3.1.5",
      "nanoid": "3.3.12",
      "serialize-javascript": "7.0.5"
    },
    "mocha@10.8.2": {
      "serialize-javascript": "7.0.5"
    },
    "solc@0.8.26": {
      "tmp": "0.2.7"
    },
    "serialize-javascript": "7.0.5",
    "tmp": "0.2.7",
    "tmp-promise@2.1.1": {
      "tmp": "0.2.7"
    },
    "undici": "6.24.0"
  },
  "engines": {
    "node": ">=20"
  }
}
