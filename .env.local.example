# Continuity Protocol local overrides.
# DEV ONLY. Copy to .env.local only for local experimentation.
# Do not commit .env.local and do not place production or mainnet secrets here.

# Local Docker Compose services
TSL_DATABASE_URL=postgres://tsl:tsl_dev_only@localhost:15432/tsl
TSL_QUEUE_URL=redis://localhost:6379

# Local Hardhat chain
TSL_SETTLEMENT_RPC_URL=http://127.0.0.1:8545
TSL_SETTLEMENT_BACKEND=eip155:31337
TSL_CHECKPOINT_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
TSL_TRUST_ID_REGISTRY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
TSL_REVOCATION_REGISTRY_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
TSL_PROVIDER_REGISTRY_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
TSL_GOVERNANCE_REGISTRY_ADDRESS=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9

# DEV ONLY: public Hardhat account 0 private key.
TSL_SETTLEMENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional local identities
TSL_RELAY_ID=did:tsl:relay:dev
TSL_RELAY_SIGNATURE=0x01
TSL_SCORING_PROVIDER_ID=did:tsl:provider:local
