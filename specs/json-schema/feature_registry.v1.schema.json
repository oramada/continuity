{
  "$id": "https://spec.tsl.network/schemas/feature_registry.v1.schema.json",
  "type": "object",
  "required": ["type", "registry_id", "feature_ids", "feature_definitions", "issued_at"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "tsl.feature_registry.v1" },
    "registry_id": { "type": "string" },
    "feature_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "feature_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature_id", "value_type", "privacy_class", "source"],
        "additionalProperties": false,
        "properties": {
          "feature_id": { "type": "string" },
          "value_type": { "enum": ["bps", "boolean", "count", "duration", "commitment"] },
          "privacy_class": { "enum": ["public", "aggregate", "pairwise", "local_only", "private"] },
          "attack_model": { "type": "array", "items": { "type": "string" } },
          "source": { "enum": ["verified_event", "receipt", "attestation", "graph", "sybil", "drift", "local_context"] }
        }
      }
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "signature": { "type": "string", "pattern": "^0x[0-9a-f]+$" }
  }
}
