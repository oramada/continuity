{
  "$id": "https://spec.tsl.network/schemas/drift_report.v1.schema.json",
  "type": "object",
  "required": [
    "type",
    "subject",
    "computed_at",
    "baseline_window_days",
    "observation_window_days",
    "drift_score_bps",
    "drift_label",
    "action",
    "reason_codes",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "tsl.drift_report.v1"
    },
    "subject": {
      "type": "string",
      "pattern": "^did:tsl:"
    },
    "issuer": {
      "type": "string",
      "pattern": "^did:tsl:"
    },
    "drift_profile_id": {
      "type": "string"
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "baseline_window_days": {
      "type": "integer",
      "minimum": 1
    },
    "observation_window_days": {
      "type": "integer",
      "minimum": 1
    },
    "coverage_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "dcrit_bps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000
    },
    "dormant_penalty_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "key_penalty_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "feature_history_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "baseline_profile_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "covariance_profile_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "robust_covariance_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "mahalanobis_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "cohort_baseline_profile_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "uncertainty_widening_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "last_verified_event_at": {
      "type": "string",
      "format": "date-time"
    },
    "days_since_last_verified_event": {
      "type": "integer",
      "minimum": 0
    },
    "sparse_mode": {
      "enum": ["none", "insufficient_baseline", "cohort_baseline"]
    },
    "recomputation_status": {
      "enum": ["not_supplied", "recomputed_match", "recomputed_mismatch", "provider_claim"]
    },
    "drift_score_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "drift_label": {
      "enum": [
        "stable",
        "minor",
        "moderate",
        "high",
        "severe",
        "dormant_reactivation",
        "insufficient_baseline"
      ]
    },
    "action": {
      "enum": [
        "none",
        "lower_confidence",
        "step_up",
        "human_review",
        "temporary_block"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "component_scores_bps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "graph": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "action": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "cadence": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "claim": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "agent": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "local": { "type": "integer", "minimum": 0, "maximum": 10000 }
      }
    },
    "signature": {
      "type": "string",
      "pattern": "^0x[0-9a-f]+$"
    }
  }
}
