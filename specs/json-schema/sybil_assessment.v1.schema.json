{
  "$id": "https://spec.tsl.network/schemas/sybil_assessment.v1.schema.json",
  "type": "object",
  "required": [
    "type",
    "subject",
    "issuer",
    "sybil_profile_id",
    "graph_profile_id",
    "seed_set_commitment",
    "evidence_commitment",
    "cluster_id_commitment",
    "computed_at",
    "adversary_tier_assumed",
    "cluster_concentration_bps",
    "trusted_escape_bps",
    "internal_receipt_ratio_bps",
    "attack_cost_minor_units",
    "cost_components",
    "expected_benefit_minor_units",
    "attack_scenario",
    "risk_score_bps",
    "risk_label",
    "privacy_level",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "tsl.sybil_assessment.v1"
    },
    "subject": {
      "type": "string",
      "pattern": "^did:tsl:"
    },
    "issuer": {
      "type": "string",
      "pattern": "^did:tsl:"
    },
    "sybil_profile_id": {
      "type": "string"
    },
    "graph_profile_id": {
      "type": "string"
    },
    "seed_set_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "evidence_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "cluster_id_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "adversary_tier_assumed": {
      "enum": [
        "B0",
        "B1",
        "B2",
        "B3",
        "B4",
        "B5"
      ]
    },
    "cluster_size_bucket": {
      "type": "string"
    },
    "cluster_concentration_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "trusted_escape_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "internal_receipt_ratio_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "creation_sync_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "issuer_reuse_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "external_diversity_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "seed_contamination_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "receipt_symmetry_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "attack_cost_minor_units": {
      "type": "integer",
      "minimum": 0
    },
    "cost_components": {
      "type": "object",
      "required": [
        "identity_cost_minor_units",
        "time_aging_cost_minor_units",
        "external_receipt_cost_minor_units",
        "attestation_cost_minor_units",
        "compromise_cost_minor_units",
        "evasion_cost_minor_units"
      ],
      "additionalProperties": false,
      "properties": {
        "identity_cost_minor_units": { "type": "integer", "minimum": 0 },
        "time_aging_cost_minor_units": { "type": "integer", "minimum": 0 },
        "external_receipt_cost_minor_units": { "type": "integer", "minimum": 0 },
        "attestation_cost_minor_units": { "type": "integer", "minimum": 0 },
        "compromise_cost_minor_units": { "type": "integer", "minimum": 0 },
        "evasion_cost_minor_units": { "type": "integer", "minimum": 0 },
        "issuer_collusion_cost_minor_units": { "type": "integer", "minimum": 0 },
        "infrastructure_consistency_cost_minor_units": { "type": "integer", "minimum": 0 }
      }
    },
    "expected_benefit_minor_units": {
      "type": "integer",
      "minimum": 0
    },
    "attack_scenario": {
      "type": "string"
    },
    "compromise_signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key_revocation_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "severe_drift_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "recovery_anomaly_bps": { "type": "integer", "minimum": 0, "maximum": 10000 }
      }
    },
    "issuer_collusion_signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issuer_reversal_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "issuer_reuse_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "low_quality_issuer_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "collusion_indicator_bps": { "type": "integer", "minimum": 0, "maximum": 10000 }
      }
    },
    "infrastructure_collusion_signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checkpoint_conflict_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "provider_auditor_disagreement_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "settlement_anomaly_bps": { "type": "integer", "minimum": 0, "maximum": 10000 }
      }
    },
    "compromise_evidence": {
      "type": "object",
      "required": ["evidence_commitment"],
      "additionalProperties": false,
      "properties": {
        "evidence_commitment": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
        "key_revocation_count": { "type": "integer", "minimum": 0 },
        "severe_drift_count": { "type": "integer", "minimum": 0 },
        "recovery_anomaly_count": { "type": "integer", "minimum": 0 }
      }
    },
    "issuer_collusion_evidence": {
      "type": "object",
      "required": ["evidence_commitment"],
      "additionalProperties": false,
      "properties": {
        "evidence_commitment": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
        "issuer_reversal_count": { "type": "integer", "minimum": 0 },
        "low_quality_issuer_count": { "type": "integer", "minimum": 0 },
        "false_attestation_count": { "type": "integer", "minimum": 0 },
        "collusion_indicator_count": { "type": "integer", "minimum": 0 }
      }
    },
    "infrastructure_collusion_evidence": {
      "type": "object",
      "required": ["evidence_commitment"],
      "additionalProperties": false,
      "properties": {
        "evidence_commitment": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
        "checkpoint_conflict_count": { "type": "integer", "minimum": 0 },
        "provider_auditor_disagreement_count": { "type": "integer", "minimum": 0 },
        "settlement_anomaly_count": { "type": "integer", "minimum": 0 },
        "selective_visibility_count": { "type": "integer", "minimum": 0 }
      }
    },
    "scenario_evidence_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_score_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "risk_label": {
      "enum": [
        "low",
        "medium",
        "elevated",
        "high",
        "insufficient_evidence"
      ]
    },
    "privacy_level": {
      "enum": [
        "cluster_commitment_only",
        "aggregate_only",
        "local_only"
      ]
    },
    "signature": {
      "type": "string",
      "pattern": "^0x[0-9a-f]+$"
    }
  }
}
