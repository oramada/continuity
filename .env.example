# Continuity Protocol local developer environment.
# DEV ONLY. These values are for local Hardhat, Docker Compose, and testnet rehearsal.
# Never reuse the private keys, passwords, or deterministic addresses for production or mainnet.

TSL_SETTLEMENT_RPC_URL=http://127.0.0.1:8545
TSL_SETTLEMENT_BACKEND=eip155:31337
# Hardhat deterministic first deployment address for CheckpointRegistry when using contracts/scripts/deploy-local.cjs
TSL_CHECKPOINT_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
TSL_TRUST_ID_REGISTRY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
TSL_REVOCATION_REGISTRY_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
TSL_PROVIDER_REGISTRY_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
TSL_GOVERNANCE_REGISTRY_ADDRESS=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
# DEV ONLY: public Hardhat account 0 private key. Never fund or use outside local development.
TSL_SETTLEMENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# DEV ONLY: docker-compose.yml maps local Postgres to host port 15432 to avoid colliding with a host Postgres on 5432.
TSL_DATABASE_URL=postgres://tsl:tsl_dev_only@localhost:15432/tsl
TSL_QUEUE_URL=redis://localhost:6379
TSL_RELAY_ID=did:tsl:relay:dev
TSL_RELAY_SIGNATURE=0x01
TSL_EPOCH_MS=300000
TSL_SHARD_PREFIX_BITS=16
TSL_SCORING_PROVIDER_ID=did:tsl:provider:local
TSL_SCORING_PROVIDER_SEED_HEX=

# Base Sepolia public testnet deployment. Use a fresh test-only wallet.
# DEV/TESTNET ONLY. Do not put a mainnet private key in this file.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
TSL_BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY
TSL_BASE_SEPOLIA_RELAY_IDS=did:tsl:relay:base-sepolia
TSL_BASE_SEPOLIA_RELAY_SIGNER=0x38953ec02af3Ee73FBE06e16Ac0bc3af485D235E
